# Frontend Environment Configuration
# Copy this file to .env and adjust values as needed

# Enable HTTPS for the frontend dev server
VITE_HTTPS_ENABLED=false

# Port for the frontend dev server
VITE_DEV_SERVER_PORT=5173

# HTTPS port for the backend proxy server
VITE_HTTPS_PORT=3443

# Default value for the "Activer la page d'accueil publique" setting
# Used as the initial fallback before the persisted application setting takes over
VITE_PUBLIC_HOME=false

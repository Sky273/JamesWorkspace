{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    
    "allowJs": true,
    "checkJs": false,
    
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@pages/*": ["src/pages/*"],
      "@utils/*": ["src/utils/*"],
      "@services/*": ["src/services/*"],
      "@hooks/*": ["src/hooks/*"],
      "@context/*": ["src/context/*"],
      "@types/*": ["src/types/*"],
      "@root/*": ["../*"],
      "@tiptap/react": ["../node_modules/@tiptap/react/src/index.ts"],
      "@tiptap/react/*": ["../node_modules/@tiptap/react/src/*/index.ts"],
      "@tiptap/pm/*": ["../node_modules/@tiptap/pm/*/index.ts"],
      "@tiptap/core": ["../node_modules/@tiptap/core/src/index.ts"],
      "@tiptap/core/*": ["../node_modules/@tiptap/core/src/*/index.ts"],
      "@tiptap/starter-kit": ["../node_modules/@tiptap/starter-kit/src/index.ts"],
      "@tiptap/extensions": ["../node_modules/@tiptap/extensions/src/index.ts"],
      "@tiptap/extension-*": ["../node_modules/@tiptap/extension-*/src/index.ts"]
    },
    
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "../package.json",
    "../CHANGELOG.md"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "dist-node"
  ]
}

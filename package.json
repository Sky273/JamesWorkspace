{
  "name": "resume-converter",
  "private": true,
  "version": "1.8.7",
  "type": "module",
  "scripts": {
    "dev": "cd client && node --max-http-header-size=32768 ../node_modules/vite/bin/vite.js --force",
    "start:proxy": "node --max-old-space-size=2048 --expose-gc server/proxy-server.js",
    "start:pdf": "node pdf-server/server.cjs",
    "build": "cd client && node ../node_modules/vite/bin/vite.js build",
    "lint": "eslint client server --ext js,jsx,ts,tsx --report-unused-disable-directives",
    "typecheck": "tsc --noEmit -p client/tsconfig.json",
    "preview": "cd client && node ../node_modules/vite/bin/vite.js preview",
    "test": "vitest run --config server/vitest.config.js",
    "test:watch": "vitest --config server/vitest.config.js",
    "test:coverage": "vitest run --coverage --config server/vitest.config.js",
    "test:pdf": "vitest run --project pdf-server",
    "test:pdf:watch": "vitest --project pdf-server",
    "test:client": "vitest run --config client/vitest.config.ts",
    "test:client:watch": "vitest --config client/vitest.config.ts",
    "quickstart": "node scripts/quickstart.js",
    "quickstart:prod": "node scripts/quickstart.js --prod",
    "backup:db": "node server/scripts/backup-db.js",
    "migrate": "node server/scripts/migrate.js",
    "knip": "knip",
    "unused-exports": "ts-unused-exports client/tsconfig.json --showLineNumber",
    "lint:fix": "eslint client server --ext js,jsx,ts,tsx --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "docker-migrate": "node server/scripts/docker-migrate.js"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tiptap/extension-character-count": "^3.20.3",
    "@tiptap/extension-code-block-lowlight": "^3.20.3",
    "@tiptap/extension-color": "^3.20.3",
    "@tiptap/extension-highlight": "^3.20.3",
    "@tiptap/extension-image": "^3.20.3",
    "@tiptap/extension-link": "^3.20.3",

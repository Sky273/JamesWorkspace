{
  "name": "resume-converter",
  "private": true,
  "version": "1.7.7",
  "type": "module",
  "scripts": {
    "postinstall": "node ./client/scripts/copy-tinymce.js",
    "dev": "node ./client/scripts/copy-tinymce.js && cd client && node --max-http-header-size=32768 ../node_modules/vite/bin/vite.js --force",
    "start:proxy": "node --max-old-space-size=2048 --expose-gc server/proxy-server.js",
    "start:pdf": "node pdf-server/server.cjs",
    "build": "node ./client/scripts/copy-tinymce.js && cd client && node ../node_modules/vite/bin/vite.js build",
    "lint": "eslint client server --ext js,jsx,ts,tsx --report-unused-disable-directives",
    "typecheck": "tsc --noEmit -p client/tsconfig.json",
    "preview": "cd client && node ../node_modules/vite/bin/vite.js preview",
    "test": "vitest run --config server/vitest.config.js",
    "test:watch": "vitest --config server/vitest.config.js",
    "test:coverage": "vitest run --coverage --config server/vitest.config.js",
    "test:client": "vitest run --config client/vitest.config.ts",
    "test:client:watch": "vitest --config client/vitest.config.ts",
    "quickstart": "node scripts/quickstart.js",
    "quickstart:prod": "node scripts/quickstart.js --prod",
    "backup:db": "node server/scripts/backup-db.js",
    "knip": "knip",
    "unused-exports": "ts-unused-exports client/tsconfig.json --showLineNumber",
    "lint:fix": "eslint client server --ext js,jsx,ts,tsx --fix"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/three": "^0.182.0",
    "autoprefixer": "^10.4.24",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "buffer": "^6.0.3",
    "canvas": "^3.2.1",
    "classnames": "^2.5.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "dompurify": "^3.3.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.34.3",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "isomorphic-dompurify": "^2.36.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "maplibre-gl": "^5.18.0",
    "mjml-core": "^4.18.0",
    "mjml-preset-core": "^4.18.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.18.0",
    "postcss": "^8.5.6",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "^19.2.4",
    "react-dropzone": "^14.4.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.4",
    "react-intersection-observer": "^9.16.0",
    "react-map-gl": "^8.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.1",
    "speakeasy": "^2.0.0",
    "tailwindcss": "^3.4.19",
    "tesseract.js": "^7.0.0",
    "three": "^0.182.0",
    "tinymce": "^8.3.2",
    "word-extractor": "^1.0.4",
    "zod": "^4.3.6"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^11.0.0",
    "html-minifier": "npm:html-minifier-terser@^7.2.0",
    "bn.js": "^5.2.3",
    "elliptic": "^6.6.1",
    "esbuild": "^0.25.0",
    "browserify-sign": {
      "elliptic": "^6.6.1"
    },
    "create-ecdh": {
      "elliptic": "^6.6.1"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@headlessui/react": "^2.2.9",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "supertest": "^7.2.2",
    "terser": "^5.46.0",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^5.4.21",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^2.1.9"
  }
}

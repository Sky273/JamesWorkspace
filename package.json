{
  "name": "resume-converter",
  "private": true,
  "version": "1.5.3",
  "type": "module",
  "scripts": {
    "postinstall": "node ./scripts/copy-tinymce.js",
    "dev": "node ./scripts/copy-tinymce.js && node --max-http-header-size=32768 node_modules/vite/bin/vite.js --force",
    "start:proxy": "node --max-old-space-size=2048 --expose-gc proxy-server.js",
    "start:pdf": "node server.cjs",
    "build": "node ./scripts/copy-tinymce.js && vite build",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "quickstart": "node scripts/quickstart.js",
    "quickstart:prod": "node scripts/quickstart.js --prod",
    "backup:db": "node scripts/backup-db.js"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.20.5",
    "autoprefixer": "^10.4.14",
    "axios": "^1.7.8",
    "bcryptjs": "^2.4.3",
    "buffer": "^6.0.3",
    "classnames": "^2.5.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^10.12.16",
    "helmet": "^8.1.0",
    "html2pdf.js": "^0.14.0",
    "i18next": "^24.0.5",
    "i18next-browser-languagedetector": "^8.0.0",
    "isomorphic-dompurify": "^2.14.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.6.0",
    "maplibre-gl": "^5.17.0",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^4.8.69",
    "pg": "^8.18.0",
    "postcss": "^8.4.24",
    "puppeteer": "^24.36.1",
    "react": "^18.2.0",
    "react-circular-progressbar": "^2.1.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^13.5.0",
    "react-intersection-observer": "^9.4.4",
    "react-map-gl": "^8.1.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.1.1",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.0",
    "tailwindcss": "^3.3.2",
    "tesseract.js": "^7.0.0",
    "tinymce": "^8.3.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "word-extractor": "^1.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@headlessui/react": "^2.2.9",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.0.11",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  }
}

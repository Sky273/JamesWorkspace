# ============================================
# SECURITY CONFIGURATION (REQUIRED)
# ============================================

# JWT Secret (REQUIRED - must be at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CSRF Secret (REQUIRED - must be at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=your-super-secret-csrf-key-change-this-in-production

# Refresh Token Secret (RECOMMENDED - must be at least 32 characters)
# Using a separate secret for refresh tokens enhances security
# If not set, JWT_SECRET will be used as fallback (less secure)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production

# PDF server internal token (RECOMMENDED - must be at least 32 characters)
# Shared secret used only between the proxy server and the internal PDF server.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If omitted, production falls back to a derived compatibility token based on JWT_SECRET and CSRF_SECRET.
PDF_SERVER_INTERNAL_TOKEN=your-super-secret-pdf-server-internal-token-change-this-in-production

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins for CORS (comma-separated)
# Development: http://localhost:5173,http://localhost:3000,http://localhost:3002
# Production: add your production domains
# Example: http://localhost:5173,http://localhost:3000,http://localhost:3002,https://www.resumeconverter.net,https://resumeconverter.net
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3002

# Frontend URL for OAuth redirects (after Gmail authentication)
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# CAPTCHA registration protection (Cloudflare Turnstile)
# Leave TURNSTILE_SECRET_KEY empty to disable CAPTCHA enforcement on the backend.
# When TURNSTILE_SECRET_KEY is set, VITE_TURNSTILE_SITE_KEY must also be set on the frontend.
# Test keys below are suitable for local development and validation only.
# Replace both with your real Cloudflare Turnstile keys before production.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=

# PDF Server URL (for frontend to call PDF generation service)
# Development: http://localhost:3002
# Production: http://your-server-ip:3002 or https://pdf.your-domain.com
VITE_PDF_SERVER_URL=http://localhost:3002

# ============================================
# LLM API KEYS (REQUIRED)
# ============================================

# OpenAI API Key
OPENAI_API_KEY=sk-proj-YOUR-OPENAI-API-KEY-HERE

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-YOUR-ANTHROPIC-API-KEY-HERE
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-YOUR-DEEPSEEK-API-KEY-HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini API Key (used for Gemma Cloud / Google AI Studio OpenAI-compatible endpoint)
GEMINI_API_KEY=YOUR-GEMINI-API-KEY-HERE
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Hugging Face API Key (used for hosted Hugging Face router models such as MiniMaxAI/MiniMax-M2.7)
HUGGINGFACE_API_KEY=hf_YOUR_HUGGINGFACE_API_KEY_HERE
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# GLM API Key (Z.AI / OpenAI-compatible)
GLM_API_KEY=YOUR-GLM-API-KEY-HERE
GLM_BASE_URL=https://api.z.ai/api/paas/v4

# MiniMax API Key
MINIMAX_API_KEY=sk-api-YOUR-MINIMAX-API-KEY-HERE
MINIMAX_OPENAI_BASE_URL=https://api.minimax.io/v1
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# Enable MiniMax highspeed models (MiniMax-*-highspeed) only if your MiniMax plan supports them.
# false: hide highspeed variants and fall back to the corresponding standard model.
# true: expose and allow selecting MiniMax highspeed variants.
MINIMAX_ENABLE_HIGHSPEED_MODELS=false

# Profile matching LLM concurrency cap (0 = provider defaults, max 100)
PROFILE_MATCHING_LLM_MAX_CONCURRENCY=0

# Profile matching LLM batch size (0 = provider defaults, max 100)
# Provider defaults:
# - MiniMax: 6
# - DeepSeek: 4
# - Other providers: 12
PROFILE_MATCHING_LLM_BATCH_SIZE=0

# Profile matching candidate prefilter cap before LLM scoring
# 0 = disable prefilter and send all in-scope CVs into the batching pipeline
PROFILE_MATCHING_LLM_PREFILTER_CAP=100

# Profile matching local pre-ranking weights
# Tune these only if you need to favor some signal families before LLM scoring.
PROFILE_MATCHING_LOCAL_SKILL_WEIGHT=6
PROFILE_MATCHING_LOCAL_TOOL_WEIGHT=4
PROFILE_MATCHING_LOCAL_INDUSTRY_WEIGHT=3
PROFILE_MATCHING_LOCAL_SOFTSKILL_WEIGHT=2
PROFILE_MATCHING_LOCAL_TITLE_EXACT_WEIGHT=5
PROFILE_MATCHING_LOCAL_TITLE_TOKEN_WEIGHT=2
PROFILE_MATCHING_LOCAL_COVERAGE_MULTIPLIER=3
LLM_RUNTIME_UNAVAILABLE_TTL_MS=21600000

# Batch export safeguards
# Maximum number of export operations per batch job.
# Default: 300
# Hard cap: 300 even if a higher value is configured.
BATCH_EXPORT_MAX_OPERATIONS=300

# Number of files processed concurrently per export batch slice.
# Default when unset: 100
BATCH_EXPORT_BATCH_SIZE=100

# Ollama local inference configuration
# If the app runs directly on your machine, keep http://127.0.0.1:11434
# If the app runs in Docker and Ollama runs on the host PC, prefer http://host.docker.internal:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_AUTO_PULL=true
OLLAMA_REQUEST_TIMEOUT_MS=300000

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resumeconverter
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_MAX_CONNECTIONS=20

# SSL Configuration:
# - false    : No SSL (development only)
# - true     : SSL with certificate validation (recommended for production)
# - relaxed  : SSL without certificate validation (for self-signed certs)
POSTGRES_SSL=false

# Connection retry settings
POSTGRES_MAX_RETRIES=5
POSTGRES_RETRY_DELAY=1000

# Cache backend
# - memory: in-process cache (default)
# - redis: shared cache across instances
# Runtime note:
# - CACHE_BACKEND is the requested backend
# - if Redis cannot be reached, the app automatically falls back to memory
# - admin diagnostics expose both the configured backend and the effective backend
CACHE_BACKEND=memory
CACHE_REDIS_URL=redis://127.0.0.1:6379
CACHE_KEY_PREFIX=resumeconverter

# Database URL (alternative to individual settings)
# DATABASE_URL=postgresql://resume_user:password@localhost:5432/resumeconverter

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Backend log level: error, warn, info, debug
# Pre-production: info (shows error, warn, info)
# Production: warn (shows error, warn only)
# Development: debug (shows all logs)
LOG_LEVEL=info

# Frontend log level: error, warn, info, debug
# Production: error (only critical errors)
# Pre-production: warn (errors and warnings)
# Development: info (key actions, not debug spam)
VITE_LOG_LEVEL=info

# Log buffer size (number of logs kept in memory for admin viewing)
LOG_BUFFER_SIZE=1000

# ============================================
# FRANCE TRAVAIL API (Optional - for Market Radar)
# ============================================

# France Travail API credentials for labor market data
# Register at: https://francetravail.io/
# FRANCE_TRAVAIL_CLIENT_ID=your-client-id
# FRANCE_TRAVAIL_CLIENT_SECRET=your-client-secret

# ============================================
# CHATBOT CONFIGURATION
# ============================================

# The chatbot uses the configured LLM (OpenAI or Anthropic) to assist users
# It automatically loads the USER_GUIDE.md file to provide context
# No additional configuration needed - just ensure LLM API keys are set above

# ============================================
# SERVER CONFIGURATION
# ============================================

# Proxy server port
PROXY_PORT=3001

# Node environment (development, production)
NODE_ENV=development

# ============================================
# HTTPS CONFIGURATION (Optional)
# ============================================

# Enable HTTPS (set to true to use HTTPS)
HTTPS_ENABLED=false

# HTTPS port (default: 3443)
HTTPS_PORT=3443

# Certificate files should be placed in /certificates folder:
# - private.key (private key)
# - certificate.crt (SSL certificate)

# ============================================
# GMAIL OAUTH CONFIGURATION (Optional - for CV email sending)
# ============================================

# Google OAuth credentials for Gmail integration AND Google Sign-In
# Create at: https://console.cloud.google.com/apis/credentials
# Required scopes: gmail.compose, userinfo.email, userinfo.profile
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Gmail OAuth callback (for email sending)
# For development: http://localhost:3001/api/mail/callback/gmail
# For production: https://your-domain.com/api/mail/callback/gmail
GOOGLE_REDIRECT_URI=https://your-domain.com/api/mail/callback/gmail
# Google Sign-In OAuth callback (for authentication)
# For development: http://localhost:3001/api/auth/google/callback
# For production: https://your-domain.com/api/auth/google/callback
GOOGLE_AUTH_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# Encryption key for OAuth tokens (32 bytes hex = 64 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MAIL_TOKEN_ENCRYPTION_KEY=your-64-character-hex-encryption-key-for-oauth-tokens

# ============================================
# SECURITY NOTES
# ============================================
# 
# 1. NEVER commit this file to version control
# 2. Use strong, randomly generated secrets (minimum 32 characters)
# 3. Rotate secrets regularly (every 90 days recommended)
# 4. Use different secrets for development and production
# 5. Store production secrets in a secure vault (AWS Secrets Manager, Azure Key Vault, etc.)
# 6. Set NODE_ENV=production in production environments
# 7. Update ALLOWED_ORIGINS to match your production domain(s)
#

